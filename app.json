{
  "name": "NAPPIER-XMD",
  "description": "Advanced WhatsApp Bot with 500+ Commands",
  "repository": "https://github.com/gathara1/NAPPIER-XMD",
  "keywords": ["whatsapp", "bot", "baileys", "xmd", "nappier", "group-manager"],
  "buildpacks": [
    {"url": "heroku/nodejs"},
    {"url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest.git"}
  ],
  "env": {
    "SESSION_SECRET": {
      "description": "Your session secret key",
      "required": true,
      "value": "nappier-xmd-secret-2026"
    },
    "AUTO_READ_MESSAGES": {
      "description": "Auto read messages: off, all, dm, groups",
      "value": "off"
    },
    "AUTO_REACT": {
      "description": "Auto react: off, all, dm, groups",
      "value": "off"
    },
    "ANTILINK_ENABLED": {
      "description": "Enable anti-link protection",
      "value": "false"
    }
  },
  "formation": {
    "web": {"quantity": 1, "size": "eco"}
  },
  "stack": "heroku-22"
}
